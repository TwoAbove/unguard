{
  "name": "unguard",
  "version": "0.16.2",
  "description": "Detect overdefensive AI-generated code",
  "author": "Seva Maltsev <me@seva.dev> (https://seva.dev)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TwoAbove/unguard.git"
  },
  "homepage": "https://github.com/TwoAbove/unguard#readme",
  "bugs": {
    "url": "https://github.com/TwoAbove/unguard/issues"
  },
  "keywords": [
    "typescript",
    "linter",
    "static-analysis",
    "code-quality",
    "type-safety",
    "ai",
    "ai-generated-code",
    "code-review",
    "defensive-programming",
    "eslint"
  ],
  "type": "module",
  "bin": {
    "unguard": "./bin/unguard.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "bin",
    "dist",
    "schema.json"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "node ./node_modules/tsc7/bin/tsc",
    "lint:biome": "biome lint src tests/**/*.test.ts tests/harness.ts",
    "lint": "npm run lint:biome",
    "test": "vitest run",
    "test:watch": "vitest",
    "scan": "node ./bin/unguard.mjs scan",
    "scan:strict": "node ./bin/unguard.mjs scan --strict",
    "demo": "vhs demo/demo.tape && ffmpeg -y -loglevel error -sseof -0.5 -i demo/demo.gif -frames:v 1 -update 1 /tmp/unguard-demo-frame.png",
    "prepublishOnly": "npm run build && npm run test"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.5",
    "picocolors": "^1.1.1",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.20.1",
    "tsc7": "npm:typescript@^7.0.2",
    "tsdown": "^0.22.4",
    "vitest": "^4.0.18"
  }
}
