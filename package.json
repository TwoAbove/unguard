{
  "name": "unguard",
  "version": "0.4.2",
  "description": "Unslop",
  "author": "TwoAbove",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TwoAbove/unguard.git"
  },
  "homepage": "https://github.com/TwoAbove/unguard#readme",
  "bugs": {
    "url": "https://github.com/TwoAbove/unguard/issues"
  },
  "type": "module",
  "bin": {
    "unguard": "./bin/unguard.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "scan": "node ./bin/unguard.mjs scan .",
    "scan:strict": "node ./bin/unguard.mjs scan . --strict",
    "prepublishOnly": "npm run build && npm run test"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "fast-glob": "^3.3.3",
    "oxc-parser": "^0.114.0",
    "oxc-walker": "^0.7.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@oxc-project/types": "^0.114.0",
    "@types/node": "^25.3.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
